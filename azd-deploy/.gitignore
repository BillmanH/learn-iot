# azd environment files contain secrets — never commit them
.azure/

# User config — contains subscription ID and resource group name
# Copy config.template.yaml → config.yaml and fill in your values
config.yaml

# SSH key files generated by pre-provision.ps1
*.pem
*.pub

# Local override parameters
main.parameters.json

# Bicep compiled output (generated by `az bicep build`, not needed at runtime)
main.json
